# shellcheck shell=bash
# =============================================================================
# aidevops Feature Toggles — Default Configuration
# =============================================================================
#
# This file documents all available feature toggles and their defaults.
# DO NOT edit this file — it is overwritten on every update.
#
# To customise, create or edit:
#   ~/.config/aidevops/feature-toggles.conf
#
# Or use the CLI:
#   aidevops config set auto_update false
#   aidevops config list
#   aidevops config reset auto_update
#
# Format: KEY=value (shell-sourceable). Lines starting with # are comments.
# Values: true | false (booleans), or strings/numbers where noted.
#
# Environment variables (e.g. AIDEVOPS_AUTO_UPDATE=false) always take
# precedence over this file. The priority order is:
#   1. Environment variable (highest)
#   2. ~/.config/aidevops/feature-toggles.conf (user overrides)
#   3. This defaults file (lowest)
# =============================================================================

# -----------------------------------------------------------------------------
# Auto-Update
# -----------------------------------------------------------------------------
# Automatically check for and install aidevops updates (every 10 min).
# Set to false to disable all automatic updates. You can still update
# manually with: aidevops update
# Env override: AIDEVOPS_AUTO_UPDATE
auto_update=true

# Minutes between update checks (default: 10).
# Env override: AIDEVOPS_UPDATE_INTERVAL
update_interval=10

# -----------------------------------------------------------------------------
# Skill Auto-Update
# -----------------------------------------------------------------------------
# Automatically check imported skills for upstream changes (daily).
# Env override: AIDEVOPS_SKILL_AUTO_UPDATE
skill_auto_update=true

# Hours between skill freshness checks (default: 24).
# Env override: AIDEVOPS_SKILL_FRESHNESS_HOURS
skill_freshness_hours=24

# -----------------------------------------------------------------------------
# Tool Auto-Update
# -----------------------------------------------------------------------------
# Automatically update installed tools (npm, brew, pip) when user is idle.
# Env override: AIDEVOPS_TOOL_AUTO_UPDATE
tool_auto_update=true

# Hours between tool freshness checks (default: 6).
# Env override: AIDEVOPS_TOOL_FRESHNESS_HOURS
tool_freshness_hours=6

# Required user idle hours before tool updates run (default: 6).
# Env override: AIDEVOPS_TOOL_IDLE_HOURS
tool_idle_hours=6

# -----------------------------------------------------------------------------
# OpenCode Configuration Management
# -----------------------------------------------------------------------------
# Allow setup.sh to modify opencode.json (agents, MCPs, settings).
# Set to false if you manage opencode.json manually and don't want
# aidevops to overwrite your changes.
manage_opencode_config=true

# -----------------------------------------------------------------------------
# Claude Code Configuration Management
# -----------------------------------------------------------------------------
# Allow setup.sh to modify Claude Code config (commands, MCPs, settings).
# Set to false if you manage Claude Code config manually.
manage_claude_config=true

# -----------------------------------------------------------------------------
# Supervisor Pulse
# -----------------------------------------------------------------------------
# Enable the autonomous supervisor pulse scheduler (dispatches workers,
# merges PRs, evaluates results). Set to false to disable autonomous
# orchestration entirely.
# Env override: AIDEVOPS_SUPERVISOR_PULSE
supervisor_pulse=true

# -----------------------------------------------------------------------------
# Repo Sync
# -----------------------------------------------------------------------------
# Enable daily git pull --ff-only on clean repos.
# Env override: AIDEVOPS_REPO_SYNC
repo_sync=true

# -----------------------------------------------------------------------------
# Session Greeting
# -----------------------------------------------------------------------------
# Show version check and update prompt when starting an AI session.
# Set to false for a quieter startup experience.
session_greeting=true

# -----------------------------------------------------------------------------
# Safety Hooks
# -----------------------------------------------------------------------------
# Install git pre-commit and pre-push safety hooks that block
# destructive commands. Set to false if hooks conflict with your workflow.
safety_hooks=true

# -----------------------------------------------------------------------------
# Shell Aliases
# -----------------------------------------------------------------------------
# Add aidevops shell aliases to .zshrc/.bashrc during setup.
# Set to false if you prefer to manage your shell config manually.
shell_aliases=true

# -----------------------------------------------------------------------------
# Onboarding Prompt
# -----------------------------------------------------------------------------
# Offer to launch /onboarding after setup.sh completes.
# Set to false to skip the prompt.
onboarding_prompt=true

# -----------------------------------------------------------------------------
# OpenClaw Auto-Update
# -----------------------------------------------------------------------------
# Automatically check for OpenClaw updates (daily, if installed).
# Env override: AIDEVOPS_OPENCLAW_AUTO_UPDATE
openclaw_auto_update=true

# Hours between OpenClaw update checks (default: 24).
# Env override: AIDEVOPS_OPENCLAW_FRESHNESS_HOURS
openclaw_freshness_hours=24
